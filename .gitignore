personal.tfvars
dev.tfvars
stage.tfvars
prod.tfvars
test.tfvars

# Service account keys, credentials и любые секреты
*.json
*.pem
*.key
*.crt
*.p12

# OS-specific files
.DS_Store
Thumbs.db

# Editor temporary files
*~
.#*
*.swp
