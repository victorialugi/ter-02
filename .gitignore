# Local .terraform directories and files
**/.terraform/*
.terraform*
!.terraformrc

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform lock file
.terraform.lock.hcl

# Personal / secret variables
*.tfvars
*.auto.tfvars
